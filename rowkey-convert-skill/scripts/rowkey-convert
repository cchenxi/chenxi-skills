#!/usr/bin/env python3
"""Convert HBase rowkey between mixed (hbase shell), hex, and bytes array formats."""

import argparse
import re
import sys


# ---------- detection ----------

def detect_format(s: str) -> str:
    """Detect input format: 'mixed', 'hex', 'bytes', 'java_bytes', or 'annotated'."""
    s = s.strip()
    if not s:
        return "empty"
    if s == '[]':
        return "empty"
    if re.match(r'^\[.*\]$', s):
        inner = s.strip()[1:-1]
        if inner and any(t.strip().startswith('-') for t in inner.split(',')):
            return "java_bytes"
        return "bytes"
    if '\n' in s:
        lines = s.split('\n')
        hex_tokens = lines[0].strip().split()
        if hex_tokens and all(re.fullmatch(r'[0-9a-fA-F]{2}', t) for t in hex_tokens):
            return "annotated"
    if re.search(r'\\x[0-9a-fA-F]{2}', s):
        return "mixed"
    if re.fullmatch(r'[0-9a-fA-F]+', s) and len(s) % 2 == 0:
        return "hex"
    # ambiguous: could be all-printable mixed like "hello"
    return "mixed"


# ---------- parsing ----------

def parse_mixed(s: str) -> list[int]:
    """Parse mixed-format string into list of byte values."""
    result = []
    i = 0
    while i < len(s):
        if s[i] == '\\' and i + 3 < len(s) and s[i+1] == 'x':
            try:
                result.append(int(s[i+2:i+4], 16))
            except ValueError:
                raise ValueError(
                    f"Invalid hex escape '\\x{s[i+2:i+4]}' at position {i}. "
                    f"Expected two hex digits after \\x, e.g. \\x00, \\xFF."
                )
            i += 4
        else:
            result.append(ord(s[i]))
            i += 1
    return result


def parse_hex(s: str) -> list[int]:
    """Parse even-length hex string into list of byte values."""
    s = s.strip()
    return [int(s[i:i+2], 16) for i in range(0, len(s), 2)]


def parse_bytes(s: str) -> list[int]:
    """Parse bytes array string like '[0, 255, 0xFF]' into list of byte values."""
    inner = s.strip().strip('[]')
    if not inner:
        return []
    result = []
    for token in inner.split(','):
        token = token.strip()
        if token.startswith('0x') or token.startswith('0X'):
            val = int(token, 16)
        else:
            val = int(token)
        if not (0 <= val <= 255):
            raise ValueError(f"Byte value out of range: {val}")
        result.append(val)
    return result


def parse_java_bytes(s: str) -> list[int]:
    """Parse Java signed byte array like '[-1, -2, -3]' into unsigned byte values."""
    inner = s.strip().strip('[]')
    if not inner:
        return []
    result = []
    for token in inner.split(','):
        token = token.strip()
        if token.startswith('0x') or token.startswith('0X'):
            val = int(token, 16)
        else:
            val = int(token)
        if not (-128 <= val <= 255):
            raise ValueError(f"Byte value out of range: {val}")
        result.append(val if val >= 0 else val + 256)
    return result


def parse_annotated(s: str) -> list[int]:
    """Parse annotated (hex dump) format into list of byte values."""
    hex_line = s.strip().split('\n')[0].strip()
    return [int(t, 16) for t in hex_line.split()]


def parse_input(s: str) -> list[int]:
    """Auto-detect format and parse into byte list."""
    fmt = detect_format(s)
    if fmt == "empty":
        raise ValueError("Empty input. Provide a mixed string (e.g. \\x00\\xFFhello), "
                         "hex string (e.g. 00FF6865), or bytes array (e.g. [0, 255, 104]).")
    elif fmt == "mixed":
        return parse_mixed(s)
    elif fmt == "hex":
        return parse_hex(s)
    elif fmt == "bytes":
        return parse_bytes(s)
    elif fmt == "java_bytes":
        return parse_java_bytes(s)
    elif fmt == "annotated":
        return parse_annotated(s)
    raise ValueError(f"Unsupported format: {s[:50]}")


# ---------- formatting ----------

def format_hex(byte_list: list[int]) -> str:
    """Format as continuous hex string, e.g. 00FF6865."""
    return ''.join(f'{b:02X}' for b in byte_list)


def format_escaped(byte_list: list[int]) -> str:
    """Format as \\xHH escaped string, e.g. \\x00\\xFF\\x68\\x65."""
    return ''.join(f'\\x{b:02X}' for b in byte_list)


def format_bytes(byte_list: list[int]) -> str:
    """Format as bytes array, e.g. [0, 255, 104, 101]."""
    return '[' + ', '.join(str(b) for b in byte_list) + ']'


def format_java_bytes(byte_list: list[int]) -> str:
    """Format as Java signed byte array, e.g. [0, -1, 104, 101]."""
    def to_signed(b: int) -> int:
        return b if b < 128 else b - 256
    return '[' + ', '.join(str(to_signed(b)) for b in byte_list) + ']'


def format_annotated(byte_list: list[int]) -> str:
    """Format as hex dump with ASCII annotation line."""
    hex_line = ' '.join(f'{b:02X}' for b in byte_list)
    ascii_line = ' '.join(_char_for_annotate(b) for b in byte_list)
    return hex_line + '\n' + ascii_line


def format_mixed(byte_list: list[int]) -> str:
    """Format as mixed string: printable ASCII as chars, rest as \\xHH."""
    result = []
    for b in byte_list:
        if 0x20 <= b <= 0x7E:
            result.append(chr(b))
        else:
            result.append(f'\\x{b:02X}')
    return ''.join(result)


def _char_for_annotate(b: int) -> str:
    """Single char for annotated line: printable ASCII, else '.'."""
    if 0x20 <= b <= 0x7E:
        return ' ' + chr(b) + ' '
    else:
        return ' . '


# ---------- extract ----------

def extract_rowkeys(s: str, fmt_filter: str) -> None:
    """Extract rowkey candidates from mixed text (e.g. log lines)."""
    found = False

    # Find \xHH sequences
    for m in re.finditer(r'(\\x[0-9a-fA-F]{2})+', s):
        found = True
        print(f'--- rowkey at offset {m.start()} ---')
        try:
            byte_list = parse_mixed(m.group())
        except ValueError as e:
            print(f'  (parse error: {e})')
            continue
        print_formats(byte_list, fmt_filter, m.group())

    if not found:
        print('No rowkey candidates found in input.')


# ---------- output ----------

def print_formats(byte_list: list[int], fmt: str, input_str: str = '', detected_fmt: str = '') -> None:
    """Print byte list in the requested format(s)."""
    formats = [
        ('mixed',     'Mixed',     format_mixed(byte_list)),
        ('hex',       'Hex',       format_hex(byte_list)),
        ('escaped',   'Escaped',   format_escaped(byte_list)),
        ('annotated', 'Annotated', format_annotated(byte_list)),
        ('bytes',     'Bytes',     format_bytes(byte_list)),
        ('java',      'Java bytes', format_java_bytes(byte_list)),
    ]

    if fmt == 'all':
        if input_str:
            print(f'[Input] ({detected_fmt})\n{input_str}\n')
        for _, label, value in formats:
            print(f'[{label}]\n{value}\n')
    else:
        for key, label, value in formats:
            if key == fmt:
                print(f'[{label}]\n{value}')
                break


# ---------- batch ----------

def batch_process(input_text: str, fmt: str, max_length: int) -> int:
    """Process input line-by-line as independent rowkeys. Returns exit code."""
    lines = input_text.split('\n')
    success_count = 0
    fail_count = 0

    for i, line in enumerate(lines, start=1):
        line = line.strip()
        if not line:
            continue

        try:
            byte_list = parse_input(line)
        except ValueError as e:
            print(f'Warning: line {i}: {e}', file=sys.stderr)
            fail_count += 1
            continue

        if max_length > 0 and len(byte_list) > max_length:
            print(
                f'Warning: line {i}: input is {len(byte_list)} bytes, '
                f'exceeds --max-length {max_length}.',
                file=sys.stderr
            )
            fail_count += 1
            continue

        detected_fmt = detect_format(line)
        if fmt == 'all':
            print(f'--- [{i}] ({detected_fmt}) ---')
            print_formats(byte_list, fmt, line, detected_fmt)
        else:
            for key, label, value in [
                ('mixed', None, format_mixed(byte_list)),
                ('hex', None, format_hex(byte_list)),
                ('escaped', None, format_escaped(byte_list)),
                ('annotated', None, format_annotated(byte_list)),
                ('bytes', None, format_bytes(byte_list)),
                ('java', None, format_java_bytes(byte_list)),
            ]:
                if key == fmt:
                    print(value)
                    break
        success_count += 1

    if fail_count > 0 and success_count == 0:
        return 1
    return 0


# ---------- main ----------

def main():
    parser = argparse.ArgumentParser(
        description='Convert HBase rowkey between mixed (hbase shell), hex, escapped,'
                    ' bytes array, and annotated formats.'
    )
    parser.add_argument(
        'input', type=str, nargs='?',
        help='Rowkey in mixed (\\x00\\xFFhello), hex (00FF68656C6C6F), bytes ([0, 255, 104]), '
             'or annotated (hex dump) format. Use "-" or omit with -e for stdin.'
    )
    parser.add_argument(
        '--format', '-f',
        choices=['hex', 'escaped', 'bytes', 'java', 'annotated', 'mixed', 'all'],
        default='all',
        help='Output format (default: all)'
    )
    parser.add_argument(
        '--max-length', '-m', type=int, default=0,
        help='Maximum input byte length (default: 0 = no limit)'
    )
    parser.add_argument(
        '-e', '--extract', action='store_true',
        help='Extract rowkeys from mixed text (e.g. log lines containing \\xHH sequences)'
    )
    parser.add_argument(
        '-b', '--batch', action='store_true',
        help='Batch mode: treat each line of input as an independent rowkey'
    )
    args = parser.parse_args()

    # Read from stdin if needed (use binary mode + latin-1 to preserve all byte values)
    if args.input is None or args.input == '-':
        raw = sys.stdin.buffer.read()
        args.input = raw.decode('latin-1').strip()
        if not args.input:
            print('Error: no input provided (stdin was empty).', file=sys.stderr)
            sys.exit(1)

    if args.batch and args.extract:
        print('Error: --batch and --extract are mutually exclusive.', file=sys.stderr)
        sys.exit(1)

    if args.extract:
        extract_rowkeys(args.input, args.format)
        return

    if args.batch:
        sys.exit(batch_process(args.input, args.format, args.max_length))

    try:
        byte_list = parse_input(args.input)
    except ValueError as e:
        print(f'Error: {e}', file=sys.stderr)
        sys.exit(1)

    if args.max_length > 0 and len(byte_list) > args.max_length:
        print(
            f'Error: input is {len(byte_list)} bytes, exceeds --max-length {args.max_length}. '
            f'Increase --max-length or trim the input.',
            file=sys.stderr
        )
        sys.exit(1)

    print_formats(byte_list, args.format, args.input, detect_format(args.input))


if __name__ == '__main__':
    main()
